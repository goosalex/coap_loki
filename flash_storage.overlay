/ {
    chosen {
        zephyr,storage = &nvs_storage;
        	zephyr,flash = &flash0;
    };
};

&flash0 {
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        nvs_storage: partition@f0000 {
            label = "nvs_storage";
            reg = <0x000f0000 0x00010000>;
        };
    };
};


