module-str = Display LVGL and others
source "${ZEPHYR_BASE}/subsys/logging/Kconfig.template.log_config"

config LOKI_MOTOR1PIN
	int "Pin for Motor controller IN1."
	default 13
	range 0 31

config LOKI_MOTOR2PIN
	int "Pin for Motor controller IN2."
	default 15
	range 0 31

config LOKI_MOTOR0PIN
	int "Spare pin for Motor controller."
	default 14
	range 0 31

config LVGL_DISPLAY_UPDATE_PERIOD_MS
	int "Display update period in milliseconds"
	default 0
	range 0 10000
	help
	  This option sets the period for updating the display in milliseconds.
	  A lower value will result in more frequent updates, while a higher value
	  will reduce the update frequency.

menu "Loki settings storage"

config LOKI_CLEAR_SETTINGS_NEW_VERSION
	bool "Wipe NVS settings when firmware MAJOR.MINOR changes"
	default y
	help
	  When enabled, init_and_optionally_clear_nvs() calls nvs_clear() on
	  the chosen `zephyr,storage` partition if the firmware's MAJOR.MINOR
	  SemVer differs from the value stored in flash. This deletes every
	  record in that partition, including BLE bonds, Thread network data,
	  and the loki/* keys — i.e. it is a factory reset gated on
	  version bumps.

	  Useful while the settings schema is in flux during development.
	  Turn off once the schema is stable so that user-set names, DCC
	  addresses, and joined Thread networks survive firmware upgrades.

config LOKI_CLEAR_SETTINGS_NEW_BUILD
	bool "Wipe NVS settings on every new build number"
	default n
	help
	  Wipes the settings partition whenever APP_BUILD_NUMBER (an embedded
	  build timestamp) differs from the value stored in flash. Effectively
	  a factory reset on every flash. Convenient during heavy iteration;
	  rarely what you want in a shipped firmware.

endmenu

menu "BLE advertising lifecycle"

config LOKI_BLE_OFF_AFTER_ATTACH_MINUTES
	int "Minutes to keep BLE advertising after a successful Thread attach"
	default 5
	range 0 1440
	help
	  After the loco successfully attaches to a Thread network (role becomes
	  CHILD, ROUTER or LEADER), BLE advertising is stopped after this many
	  minutes. If the Thread role goes back to DETACHED/DISABLED before then,
	  the pending stop is cancelled and advertising continues. Set to 0 to
	  disable the feature entirely (BLE advertising stays on indefinitely).
	  A CoAP PUT to /ble-recovery resumes advertising for another window of
	  the same length.

config LOKI_BLE_RECOVERY_ON_SRP_FAIL
	bool "Reopen BLE window automatically when SRP registration fails"
	default y
	help
	  When enabled, every site that detects an SRP/DNS-SD registration
	  failure — host-name set, auto-host-address mode, or any individual
	  service allocation (short-name, long-name, DCC) — calls
	  ble_lifecycle_force_recovery() to reopen the advertising window for
	  CONFIG_LOKI_BLE_OFF_AFTER_ATTACH_MINUTES. The loco then stays
	  reachable over GATT even while DNS-SD discovery is broken.

	  Turn off to treat SRP outages silently and rely on the natural Thread
	  detach path or the manual /ble-recovery CoAP endpoint to reopen BLE
	  on demand. The /ble-recovery endpoint itself is NOT gated by this
	  option — it always works regardless.

endmenu


